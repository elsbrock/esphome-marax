# Gitignore settings for ESPHome
# This is an example and may include too much for your use-case.
# You can modify this file to suit your needs.
/.esphome/
/secrets.yaml

# Firmware binaries should never be committed — they're built by CI and
# either attached to GitHub Releases (build.yml) or uploaded to the
# Pages artifact (pages.yml).
docs/*.factory.bin
docs/*.ota.bin
docs/*.elf
